#!/usr/bin/env bash
# Pre-commit hook: block any commit that introduces something that looks
# like a credential.
#
# This is a local-only safety net. The repository ALSO has GitHub
# secret-scanning push protection enabled (see SETTINGS.md / repo
# Settings → Code security → Secret scanning), which catches the same
# patterns server-side. Belt and suspenders — this hook saves a round
# trip to the remote when you accidentally `git add .env`.
#
# Install (one-time per clone):
#   git config core.hooksPath .githooks
#
# To bypass intentionally (don't unless you really mean it):
#   git commit --no-verify
#
# What it catches:
#   - Google AI Studio / Cloud API keys (AIza...)
#   - Anthropic API keys (sk-ant-api03-...)
#   - OpenAI API keys (sk-... 48 chars)
#   - AWS access keys (AKIA...)
#   - Generic high-entropy "looks like a token" hex strings 40+ chars
#     in suspicious contexts (api_key=, secret=, password=, token=)
#   - Any staged file named .env, .env.local, .env.production, etc.
#
# Edits to the hook itself: this file IS in the repo. If a future
# pattern needs adding, do it here, commit, and every clone with the
# hook installed picks it up.
#
# Exit codes:
#   0 = nothing suspicious found, commit proceeds
#   1 = at least one violation, commit blocked

set -euo pipefail

RED=$(tput setaf 1 2>/dev/null || echo "")
YELLOW=$(tput setaf 3 2>/dev/null || echo "")
RESET=$(tput sgr0 2>/dev/null || echo "")

violations=0

# 1. Block any committed-as-content .env file
ENV_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)\.env(\.|$|\.[a-zA-Z]+$)' || true)
if [ -n "$ENV_FILES" ]; then
    echo "${RED}✗ blocked: .env-style file in staging:${RESET}"
    echo "$ENV_FILES" | sed 's/^/    /'
    echo "  → either remove from staging (git restore --staged <file>)"
    echo "  → or, if intentional, add to .gitignore and never re-stage"
    violations=$((violations + 1))
fi

# 2. Pattern scan over the diff content of staged changes.
# Only scan added lines (+ prefix) — modified context lines and removals
# can contain old leaked secrets that we're FIXING.
DIFF=$(git diff --cached --no-color -U0 || true)
ADDED=$(echo "$DIFF" | grep -E '^\+[^+]' || true)

check_pattern() {
    local pattern="$1"
    local label="$2"
    local hits
    hits=$(echo "$ADDED" | grep -E "$pattern" || true)
    if [ -n "$hits" ]; then
        echo "${RED}✗ blocked: looks like ${label} in staged changes:${RESET}"
        # Show first 3 matching lines, masked
        echo "$hits" | head -3 | sed -E "s/(${pattern}).*/[REDACTED ${label}]/" | sed 's/^/    /'
        violations=$((violations + 1))
    fi
}

check_pattern 'AIza[0-9A-Za-z_-]{35}' 'Google API key (AIza...)'
check_pattern 'sk-ant-api[0-9]{2}-[0-9A-Za-z_-]{40,}' 'Anthropic API key'
check_pattern 'sk-proj-[0-9A-Za-z_-]{40,}' 'OpenAI project key'
check_pattern 'sk-[0-9A-Za-z]{48}' 'OpenAI API key'
check_pattern 'AKIA[0-9A-Z]{16}' 'AWS access key ID'
check_pattern 'ghp_[0-9A-Za-z]{36}' 'GitHub personal access token'
check_pattern 'github_pat_[0-9A-Za-z_]{82}' 'GitHub fine-grained PAT'
check_pattern 'xox[baprs]-[0-9A-Za-z-]{10,}' 'Slack token'

# 3. Generic credential-context check — high-entropy strings near
# common secret-naming patterns. Tighter than scanning all hex strings
# (which would false-positive on every commit hash). Looks for
# (api_key|secret|password|token|auth)\s*[:=]\s*<long-string>
GENERIC_HITS=$(echo "$ADDED" | grep -iE '(api[_-]?key|secret|password|passwd|token|bearer|auth)[[:space:]]*[:=][[:space:]]*["'\''][A-Za-z0-9_/+\-]{32,}["'\'']' || true)
if [ -n "$GENERIC_HITS" ]; then
    echo "${YELLOW}⚠ suspicious: credential-shaped assignment in staged changes:${RESET}"
    echo "$GENERIC_HITS" | head -3 | sed -E 's/(api[_-]?key|secret|password|passwd|token|bearer|auth)[[:space:]]*[:=][[:space:]]*["'\''][^"'\'']*["'\'']/\1=[REDACTED]/Ig' | sed 's/^/    /'
    echo "  → if these are legitimate references (e.g. variable names, "
    echo "     fixtures, or env-var names), commit anyway with --no-verify"
    violations=$((violations + 1))
fi

if [ "$violations" -gt 0 ]; then
    echo
    echo "${RED}commit blocked — $violations issue(s) above${RESET}"
    echo "to override (only if you understand the risk): git commit --no-verify"
    exit 1
fi

exit 0
