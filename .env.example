# ╔══════════════════════════════════════════════════╗
# ║          VEILGUARD — Environment Config          ║
# ╚══════════════════════════════════════════════════╝

# === LLM API Keys (set whichever you use) ===
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GOOGLE_API_KEY=AIzaxxxxx

# === LibreChat ===
PORT=3080
CREDS_KEY=your-random-32-char-string-here
CREDS_IV=your-random-16-chars
MEILI_MASTER_KEY=changeme

# === PII Gateway ===
PII_PROXY_PORT=4000
LOG_LEVEL=INFO
MIN_SCORE=0.7

# Backend URLs (defaults are fine for most cases)
ANTHROPIC_API_URL=https://api.anthropic.com
OPENAI_API_URL=https://api.openai.com
GEMINI_API_URL=https://generativelanguage.googleapis.com

# === Web Tools (optional) ===
GOOGLE_CSE_ID=
VIRUSTOTAL_API_KEY=
